generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "commonjs"
}

datasource db {
  provider = "postgresql"
}

model ApiKeys {
  id         String    @id
  name       String
  keyHash    String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model AttemptLog {
  id                String                @id
  notificationId    String
  attemptNumber     Int
  attemptedAt       DateTime              @default(now())
  workerId          String
  provider          NotificationProvider?
  success           Boolean
  providerMessageId String?
  errorCode         String?
  errorMessage      String?
  durationMs        Int?
  Notifications     Notifications         @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, attemptNumber])
  @@index([notificationId])
  @@index([workerId])
}

model DeadLetterQueue {
  id               String        @id
  notificationId   String        @unique
  failureReason    String
  attemptCount     Int
  finalAttemptTime DateTime
  errorMessage     String?
  errorCode        String?
  requeuedBy       String?
  requeuedAt       DateTime?
  createdAt        DateTime      @default(now())
  Notifications    Notifications @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([notificationId])
}

model InAppNotifications {
  id             String        @id
  notificationId String        @unique
  recipientId    String
  subject        String?
  body           String?
  read           Boolean       @default(false)
  readAt         DateTime?
  createdAt      DateTime      @default(now())
  Notifications  Notifications @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@index([recipientId, read, createdAt])
}

model NotificationQueue {
  id                String               @id
  notificationId    String               @unique
  priority          NotificationPriority @default(MEDIUM)
  workerId          String?
  visibilityTimeout DateTime?
  createdAt         DateTime             @default(now())
  Notifications     Notifications        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([priority(sort: Desc), createdAt], map: "NotificationQueue_poll_idx", where: raw("(\"visibilityTimeout\" IS NULL)"))
}

model Notifications {
  id                 String               @id
  templateId         String?
  recipientId        String
  channel            NotificationChannel
  priority           NotificationPriority @default(MEDIUM)
  status             NotificationStatus   @default(PENDING)
  subject            String?
  body               String?
  metadata           Json?
  idempotencyKey     String               @unique
  attemptCount       Int                  @default(0)
  maxAttempts        Int                  @default(5)
  scheduledAt        DateTime?
  enqueuedAt         DateTime?
  deliveredAt        DateTime?
  providerMessageId  String?
  failureReason      String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  AttemptLog         AttemptLog[]
  DeadLetterQueue    DeadLetterQueue?
  InAppNotifications InAppNotifications?
  NotificationQueue  NotificationQueue?
  Templates          Templates?           @relation(fields: [templateId], references: [id])

  @@index([recipientId])
  @@index([status])
  @@index([status, priority, createdAt])
  @@index([status, scheduledAt])
}

model Templates {
  id              String              @id
  key             String
  name            String
  version         Int                 @default(1)
  channel         NotificationChannel
  subjectTemplate String?
  bodyTemplate    String
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime
  Notifications   Notifications[]

  @@unique([key, version])
  @@index([key, isActive])
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationProvider {
  SENDGRID
  MAILGUN
  TWILIO
  IN_APP
}

enum NotificationStatus {
  SCHEDULED
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}
